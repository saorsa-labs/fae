<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- App Sandbox disabled: Fae is a Developer ID app, not App Store.
       Sandbox is incompatible with Fae's tool system (bash, arbitrary file I/O)
       and causes model cache to be isolated from the shared HuggingFace cache at
       ~/.cache/huggingface/hub/, resulting in duplicate GB-scale model downloads. -->
  <key>com.apple.security.app-sandbox</key>
  <false/>

  <!-- Hardened runtime entitlements (required for notarization even without sandbox) -->

  <!-- Network client access (web search, update checks, HuggingFace downloads) -->
  <key>com.apple.security.network.client</key>
  <true/>

  <!-- Microphone access for voice input -->
  <key>com.apple.security.device.audio-input</key>
  <true/>

  <!-- Contacts access for Apple tool integration -->
  <key>com.apple.security.personal-information.addressbook</key>
  <true/>

  <!-- Calendar and reminders access for scheduling assistance -->
  <key>com.apple.security.personal-information.calendars</key>
  <true/>

  <!-- AppleScript / JXA for Apple tool integration -->
  <key>com.apple.security.automation.apple-events</key>
  <true/>

</dict>
</plist>
