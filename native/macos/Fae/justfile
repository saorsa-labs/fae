    echo "Benchmarking {{model_id}} → ${OUTPUT}"
    "${BIN}" --model "{{model_id}}" --output "${OUTPUT}"
    ln -sf "$(basename "${OUTPUT}")" "{{benchmark_dir}}/{{short_name}}_latest.json"
    echo "Results cached: ${OUTPUT}"

# Show cached benchmark results for a model
# Usage: just benchmark-show qwen3.5-35b-a3b
benchmark-show model:
    #!/usr/bin/env bash
    set -euo pipefail
    LATEST="{{benchmark_dir}}/{{model}}_latest.json"
    if [ ! -f "${LATEST}" ]; then
        echo "No cached results for {{model}}"
        echo ""
        echo "Available results:"
        ls -1 "{{benchmark_dir}}"/*.json 2>/dev/null | sed 's|.*/||' | grep -v '_latest' || echo "  (none)"
        echo ""
        echo "Run: just benchmark {{model}}"
        exit 1
    fi
    echo "=== {{model}} (latest) ==="
    REAL=$(readlink "{{benchmark_dir}}/{{model}}_latest.json" 2>/dev/null || basename "${LATEST}")
    echo "File: ${REAL}"
    echo ""
    python3 - "${LATEST}" <<'PYEOF'
    import json, sys, os
    path = sys.argv[1]
    if os.path.islink(path):
        real = os.path.join(os.path.dirname(path), os.readlink(path))
        path = real
    with open(path) as f:
        data = json.load(f)
    print(f'Date:     {data.get("date", "unknown")}')
    print(f'Backend:  {data.get("backend", "unknown")}')
    hw = data.get('hardware', {})
    print(f'Hardware: {hw.get("arch", "?")} / {hw.get("ram_gb", "?")} GB')
    print()
    for m in data.get('models', []):
        print(f'Model:    {m["model_short"]} ({m["model_id"]})')
        print(f'Idle RAM: {m.get("idle_ram_mb", 0):.0f} MB')
        print()
        no_think = m.get('throughput_no_think', [])
        if no_think:
            print('  /no_think throughput:')
            print(f'  {"Context":<18} {"Prompt":>7} {"Gen":>5} {"TTFT":>7} {"T/s":>7} {"RAM":>8}')
            print(f'  {"-"*18} {"-"*7} {"-"*5} {"-"*7} {"-"*7} {"-"*8}')
            for r in no_think:
                ttft = r.get("first_token_latency_ms", 0)
                print(f'  {r["context_label"]:<18} {r["prompt_tokens"]:>7} {r["generated_tokens"]:>5} {ttft:>6.1f}ms {r["tokens_per_second"]:>7.1f} {r["ram_mb"]:>7.0f}M')
            print()
        think_on = m.get('throughput_think_on', [])
        if think_on:
            print('  Thinking ON throughput:')
            print(f'  {"Context":<18} {"Prompt":>7} {"Gen":>5} {"TTFT":>7} {"T/s":>7} {"RAM":>8}')
            print(f'  {"-"*18} {"-"*7} {"-"*5} {"-"*7} {"-"*7} {"-"*8}')
            for r in think_on:
                ttft = r.get("first_token_latency_ms", 0)
                print(f'  {r["context_label"]:<18} {r["prompt_tokens"]:>7} {r["generated_tokens"]:>5} {ttft:>6.1f}ms {r["tokens_per_second"]:>7.1f} {r["ram_mb"]:>7.0f}M')
            print()
        tools = m.get('tool_calling', [])
        if tools:
            correct = sum(1 for t in tools if t['correct'])
            total = len(tools)
            pct = correct/total*100 if total else 0
            print(f'  Tool calling: {correct}/{total} ({pct:.0f}%)')
            for t in tools:
                status = 'OK' if t['correct'] else 'MISS'
                print(f'    {status}: "{t["prompt"][:50]}" -> expected={t["expected_tool"]}, got={t["actual_tool"]}')
            print()
        compliance = m.get('no_think_compliance', [])
        if compliance:
            all_ok = all(c['compliant'] for c in compliance)
            print(f'  /no_think compliant: {"Yes" if all_ok else "No"}')
            print()
    PYEOF

# List all cached benchmark results
benchmark-list:
    #!/usr/bin/env bash
    set -euo pipefail
    if [ ! -d "{{benchmark_dir}}" ] || [ -z "$(ls -A "{{benchmark_dir}}" 2>/dev/null)" ]; then
        echo "No cached benchmark results."
        echo "Run: just benchmark <model>"
        exit 0
    fi
    echo "=== Cached Benchmark Results ==="
    echo ""
    # Show actual result files (not symlinks)
    for f in "{{benchmark_dir}}"/*.json; do
        [ -f "$f" ] || continue
        [ -L "$f" ] && continue  # Skip symlinks
        NAME=$(basename "$f")
        SIZE=$(wc -c < "$f" | tr -d ' ')
        echo "  ${NAME} (${SIZE} bytes)"
    done
    echo ""
    echo "Latest links:"
    for f in "{{benchmark_dir}}"/*_latest.json; do
        [ -L "$f" ] || continue
        MODEL=$(basename "$f" | sed 's/_latest\.json//')
        TARGET=$(readlink "$f" 2>/dev/null)
        echo "  ${MODEL} → ${TARGET}"
    done

# Compare two benchmark results side by side
benchmark-compare model1 model2:
    #!/usr/bin/env bash
    set -euo pipefail
    FILE1="{{benchmark_dir}}/{{model1}}_latest.json"
    FILE2="{{benchmark_dir}}/{{model2}}_latest.json"
    if [ ! -f "${FILE1}" ]; then echo "No results for {{model1}}. Run: just benchmark {{model1}}"; exit 1; fi
    if [ ! -f "${FILE2}" ]; then echo "No results for {{model2}}. Run: just benchmark {{model2}}"; exit 1; fi
    python3 - "${FILE1}" "${FILE2}" <<'PYEOF'
    import json, os, sys
    def resolve(p):
        return os.path.join(os.path.dirname(p), os.readlink(p)) if os.path.islink(p) else p
    with open(resolve(sys.argv[1])) as f: d1 = json.load(f)
    with open(resolve(sys.argv[2])) as f: d2 = json.load(f)
    m1 = d1['models'][0]
    m2 = d2['models'][0]
    print(f'Comparing: {m1["model_short"]} vs {m2["model_short"]}')
    print(f'RAM:       {m1.get("idle_ram_mb",0):.0f} MB vs {m2.get("idle_ram_mb",0):.0f} MB')
    print()
    t1 = {r['context_label']: r for r in m1.get('throughput_no_think', [])}
    t2 = {r['context_label']: r for r in m2.get('throughput_no_think', [])}
    labels = list(dict.fromkeys(list(t1.keys()) + list(t2.keys())))
    print(f'{"Context":<18} {m1["model_short"]:>14} {m2["model_short"]:>14} {"Ratio":>8}')
    print(f'{"-"*18} {"-"*14} {"-"*14} {"-"*8}')
    for label in labels:
        v1 = t1.get(label, {}).get('tokens_per_second', 0)
        v2 = t2.get(label, {}).get('tokens_per_second', 0)
        ratio = f'{v1/v2:.1f}x' if v2 > 0 else '-'
        print(f'{label:<18} {v1:>12.1f}T/s {v2:>12.1f}T/s {ratio:>8}')
    PYEOF

# ─── Validation ─────────────────────────────────────────────────────────────

# Full validation (build + test)
check: build test

# Production-focused validation for the worker-backed local runtime.
prod-check:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "==> swift build"
    swift build
    echo "==> swift test list"
    swift test list >/dev/null
    echo "==> targeted runtime diagnostics test"
    swift test --disable-swift-testing --filter HandoffTests.RuntimeContractTests/testPipelineAuxBridgeTracksLocalModelStackDiagnostics
    echo "==> targeted config/runtime contract test"
    swift test --disable-swift-testing --filter HandoffTests.RuntimeContractTests/testFaeCorePersistsThinkingLevelPatchAndConfigGet
    echo "==> worker smoke (operator)"
    printf '{"requestID":"prod-check-reset-op","command":"reset_session","role":"operator","modelID":null,"messages":null,"systemPrompt":null,"options":null}\n' | .build/debug/Fae --llm-worker --role operator >/dev/null
    echo "==> worker smoke (concierge)"
    printf '{"requestID":"prod-check-reset-con","command":"reset_session","role":"concierge","modelID":null,"messages":null,"systemPrompt":null,"options":null}\n' | .build/debug/Fae --llm-worker --role concierge >/dev/null
    echo "==> xcodebuild build (app bundle)"
    rm -rf .build/xcode-derived
    xcodebuild -resolvePackageDependencies -scheme Fae -derivedDataPath .build/xcode-derived -quiet
    xcodebuild build -scheme Fae -destination 'platform=macOS' -configuration Debug -derivedDataPath .build/xcode-derived -quiet

# ─── Bundle & Sign (local development) ──────────────────────────────────────

# Build app bundle and launch it.
# Requires signing identity: source ~/.secrets && just run-native
run-native: bundle
    open "$(cd "../../.." && pwd)/Fae.app"

# Build a standalone Fae.app with all SPM frameworks embedded and sign it.
# Requires signing identity: source ~/.secrets && just bundle
bundle:
    #!/usr/bin/env bash
    set -euo pipefail
    if [ -z "${MACOS_SIGNING_IDENTITY:-}" ]; then
        echo "Error: MACOS_SIGNING_IDENTITY not set — run: source ~/.secrets && just bundle"
        exit 1
    fi

    # Build via xcodebuild (required for Metal shader compilation).
    xcodebuild build \
        -scheme Fae \
        -configuration Debug \
        -destination 'platform=macOS,arch=arm64' \
        -derivedDataPath .build/xcode \
        -quiet

    PRODUCTS=".build/xcode/Build/Products/Debug"
    PKG_FW_DIR="$PRODUCTS/PackageFrameworks"

    # Place the bundle at the project root (consistent with CI artifact location).
    APP_BUNDLE="$(cd "../../.." && pwd)/Fae.app"
    rm -rf "$APP_BUNDLE"
    mkdir -p "$APP_BUNDLE/Contents/MacOS" "$APP_BUNDLE/Contents/Frameworks" "$APP_BUNDLE/Contents/Resources"

    cp "$PRODUCTS/Fae" "$APP_BUNDLE/Contents/MacOS/Fae"
    chmod +x "$APP_BUNDLE/Contents/MacOS/Fae"

    # acpx (ACP agent client) is installed on-demand by Fae at runtime.
    # For local dev, run `just build-acpx` then copy manually if needed.

    # Fix rpaths: remove absolute xcode build-dir paths, add @executable_path/../Frameworks.
    # The debug binary has LC_RPATH entries like /Users/.../Debug/PackageFrameworks baked in
    # at build time. When the binary is moved into a standalone app bundle, those absolute paths
    # no longer apply. Replace them with the standard @executable_path/../Frameworks rpath so
    # dyld finds the frameworks we embed in Contents/Frameworks/.
    BINARY="$APP_BUNDLE/Contents/MacOS/Fae"
    while read -r rpath; do
        if [[ "$rpath" == /Users/* ]] || [[ "$rpath" == /var/* ]]; then
            install_name_tool -delete_rpath "$rpath" "$BINARY" 2>/dev/null || true
            echo "  Removed rpath: $rpath"
        fi
    done < <(otool -l "$BINARY" | awk '/LC_RPATH/{found=1} found && /path /{print $2; found=0}')
    install_name_tool -add_rpath "@executable_path/../Frameworks" "$BINARY" 2>/dev/null || true
    echo "  Added rpath: @executable_path/../Frameworks"

    # Copy SPM resource bundles.
    for bundle_dir in "$PRODUCTS"/*.bundle "$PKG_FW_DIR"/*.bundle; do
        [ -d "$bundle_dir" ] || continue
        BNAME=$(basename "$bundle_dir")
        [ -d "$APP_BUNDLE/Contents/Resources/$BNAME" ] && continue
        cp -R "$bundle_dir" "$APP_BUNDLE/Contents/Resources/"
        echo "  Bundled: $BNAME"
    done

    # Copy Sparkle.framework — it lives in the top-level Products dir, not PackageFrameworks/.
    SPARKLE_FW="$PRODUCTS/Sparkle.framework"
    if [ ! -d "$SPARKLE_FW" ]; then
        SPARKLE_FW="$PKG_FW_DIR/Sparkle.framework"
    fi
    if [ -d "$SPARKLE_FW" ]; then
        cp -R "$SPARKLE_FW" "$APP_BUNDLE/Contents/Frameworks/"
        echo "  Embedded: Sparkle.framework"
    else
        echo "  Warning: Sparkle.framework not found"
    fi

    # Copy all SPM dynamic frameworks (MLX, MLXNN, KokoroSwift, etc.).
    if [ -d "$PKG_FW_DIR" ]; then
        for fw in "$PKG_FW_DIR"/*.framework; do
            [ -d "$fw" ] || continue
            FNAME=$(basename "$fw")
            [ "$FNAME" = "Sparkle.framework" ] && continue
            cp -R "$fw" "$APP_BUNDLE/Contents/Frameworks/"
            echo "  Embedded: $FNAME"
        done
    fi

    # Write Info.plist.
    VERSION=$(cat "../../../VERSION" 2>/dev/null || echo "0.0.0")
    cp Info.plist "$APP_BUNDLE/Contents/Info.plist"
    sed -i '' "s/__VERSION__/${VERSION}/g" "$APP_BUNDLE/Contents/Info.plist"
    sed -i '' "s|__APPCAST_URL__||g" "$APP_BUNDLE/Contents/Info.plist"

    just _sign-bundle "$APP_BUNDLE"
    echo ""
    echo "Bundle ready: $APP_BUNDLE"
    echo "Run:  open \"$APP_BUNDLE\""

# Sign an existing app bundle (inside-out order).
# Requires MACOS_SIGNING_IDENTITY to be set.
[private]
_sign-bundle app_bundle:
    #!/usr/bin/env bash
    set -euo pipefail
    if [ -z "${MACOS_SIGNING_IDENTITY:-}" ]; then
        echo "Error: MACOS_SIGNING_IDENTITY not set"
        exit 1
    fi
    APP_BUNDLE="{{app_bundle}}"

    echo "=== Signing frameworks ==="
    for fw in "$APP_BUNDLE/Contents/Frameworks"/*.framework; do
        [ -d "$fw" ] || continue
        FNAME=$(basename "$fw")
        find "$fw" -type f | while read f; do
            file "$f" | grep -q "Mach-O" || continue
            codesign --force --options runtime \
                --sign "$MACOS_SIGNING_IDENTITY" \
                --timestamp "$f" 2>/dev/null || true
        done
        codesign --force --options runtime \
            --sign "$MACOS_SIGNING_IDENTITY" \
            --timestamp "$fw"
        echo "  Signed: $FNAME"
    done

    echo "=== Signing resource bundles ==="
    for bundle in "$APP_BUNDLE/Contents/Resources"/*.bundle; do
        [ -d "$bundle" ] || continue
        find "$bundle" -type f | while read f; do
            file "$f" | grep -q "Mach-O" || continue
            codesign --force --options runtime \
                --sign "$MACOS_SIGNING_IDENTITY" \
                --timestamp "$f" 2>/dev/null || true
        done
        codesign --force --options runtime \
            --sign "$MACOS_SIGNING_IDENTITY" \
            --timestamp "$bundle"
    done

    # Entitlements.plist lives at the project root (3 levels up from native/macos/Fae/).
    ENTITLEMENTS="$(cd "../../.." && pwd)/Entitlements.plist"

    echo "=== Signing main executable ==="
    codesign --force --options runtime \
        --sign "$MACOS_SIGNING_IDENTITY" \
        --entitlements "$ENTITLEMENTS" \
        --timestamp \
        "$APP_BUNDLE/Contents/MacOS/Fae"

    echo "=== Signing .app bundle ==="
    codesign --force --options runtime \
        --sign "$MACOS_SIGNING_IDENTITY" \
        --entitlements "$ENTITLEMENTS" \
        --timestamp \
        "$APP_BUNDLE"

    echo "=== Verifying ==="
    codesign --verify --deep --strict "$APP_BUNDLE"
    echo "Signed: $APP_BUNDLE"
