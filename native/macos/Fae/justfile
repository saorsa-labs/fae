# Benchmark with custom HuggingFace model ID (for models not in registry)
# Usage: just benchmark-custom nightmedia/Qwen3.5-122B-A10B-Text-mxfp4-mlx custom-122b
benchmark-custom model_id short_name: _ensure-benchmark
    #!/usr/bin/env bash
    set -euo pipefail
    mkdir -p "{{benchmark_dir}}"
    BIN="{{benchmark_derived_data}}/Build/Products/Debug/FaeBenchmark"
    TIMESTAMP=$(date +%Y%m%d-%H%M%S)
