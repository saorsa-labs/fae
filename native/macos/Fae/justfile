# Fae — macOS voice AI assistant
# Run `just --list` for all available recipes.

# Default recipe — show available commands
default:
    @just --list

# ─── Build ──────────────────────────────────────────────────────────────────

# Build Fae (debug)
build:
    swift build

# Build Fae (release)
build-release:
    swift build -c release

# Build acpx standalone binary (requires bun)
build-acpx:
    #!/usr/bin/env bash
    set -euo pipefail
    OUTDIR="Resources/Binaries"
    mkdir -p "$OUTDIR"
    if [ -f "$OUTDIR/acpx" ]; then
        echo "acpx already built at $OUTDIR/acpx ($(du -h "$OUTDIR/acpx" | cut -f1))"
        echo "  Delete it to rebuild: rm $OUTDIR/acpx"
        exit 0
    fi
    echo "Building acpx standalone binary..."
    TMPDIR=$(mktemp -d)
    cd "$TMPDIR" && npm pack acpx@latest --silent && tar xzf acpx-*.tgz
    cd package && npm install --production --ignore-scripts 2>/dev/null || true
    bun build dist/cli.js --compile --target=bun-darwin-arm64 --outfile "$OLDPWD/$OUTDIR/acpx"
    rm -rf "$TMPDIR"
    echo "Built acpx: $(du -h "$OLDPWD/$OUTDIR/acpx" | cut -f1)"

# Build benchmark tool (requires xcodebuild for Metal shader compilation)
build-benchmark:
    xcodebuild build -scheme FaeBenchmark -destination 'platform=macOS' -configuration Debug -derivedDataPath ".build/xcode-benchmark-derived" -quiet

# Clean build artifacts
clean:
    swift package clean

# ─── Test ───────────────────────────────────────────────────────────────────

# Run all tests
test:
    swift test

# Run specific test target
test-target target:
    swift test --filter {{target}}

# ─── Benchmark ──────────────────────────────────────────────────────────────

# Directory for cached benchmark results
benchmark_dir := "../../../scripts/benchmark-results"
benchmark_derived_data := ".build/xcode-benchmark-derived"

# Build and return path to FaeBenchmark binary
[private]
_ensure-benchmark:
    #!/usr/bin/env bash
    set -euo pipefail
    # Build via xcodebuild (compiles Metal shaders that swift run cannot)
    xcodebuild build -scheme FaeBenchmark -destination 'platform=macOS' -configuration Debug -derivedDataPath "{{benchmark_derived_data}}" -quiet 2>&1 | grep -v "^$" || true
    BIN="{{benchmark_derived_data}}/Build/Products/Debug/FaeBenchmark"
    if [ ! -x "${BIN}" ]; then
        echo "ERROR: FaeBenchmark binary not built at ${BIN}"
        exit 1
    fi

# Benchmark a specific model (downloads if needed)
# Usage: just benchmark qwen3.5-35b-a3b
#        just benchmark qwen3-8b
#        just benchmark qwen3-4b
# Available models: qwen3-0.6b, qwen3-1.7b, qwen3-4b, qwen3-8b,
#                   qwen3.5-35b-a3b, qwen3.5-27b
benchmark model: _ensure-benchmark
    #!/usr/bin/env bash
    set -euo pipefail
    mkdir -p "{{benchmark_dir}}"
    BIN="{{benchmark_derived_data}}/Build/Products/Debug/FaeBenchmark"
    TIMESTAMP=$(date +%Y%m%d-%H%M%S)
    OUTPUT="{{benchmark_dir}}/{{model}}_${TIMESTAMP}.json"
    echo "Benchmarking {{model}} → ${OUTPUT}"
    "${BIN}" --model "{{model}}" --output "${OUTPUT}"
    ln -sf "$(basename "${OUTPUT}")" "{{benchmark_dir}}/{{model}}_latest.json"
    echo ""
    echo "Results cached: ${OUTPUT}"
    echo "Latest link:    {{benchmark_dir}}/{{model}}_latest.json"

# Benchmark all models (long — downloads ~40GB on first run)
benchmark-all: _ensure-benchmark
    #!/usr/bin/env bash
    set -euo pipefail
    mkdir -p "{{benchmark_dir}}"
    BIN="{{benchmark_derived_data}}/Build/Products/Debug/FaeBenchmark"
    TIMESTAMP=$(date +%Y%m%d-%H%M%S)
    OUTPUT="{{benchmark_dir}}/all_${TIMESTAMP}.json"
    echo "Benchmarking ALL models → ${OUTPUT}"
    "${BIN}" --all --output "${OUTPUT}"
    ln -sf "$(basename "${OUTPUT}")" "{{benchmark_dir}}/all_latest.json"
    echo "Results cached: ${OUTPUT}"

# Benchmark only throughput (faster — skips /no_think and tool tests)
benchmark-throughput model: _ensure-benchmark
    #!/usr/bin/env bash
    set -euo pipefail
    mkdir -p "{{benchmark_dir}}"
    BIN="{{benchmark_derived_data}}/Build/Products/Debug/FaeBenchmark"
